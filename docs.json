{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "gx",
  "colors": {
    "primary": "#06b6d4",
    "light": "#22d3ee",
    "dark": "#0891b2"
  },
  "favicon": "/favicon.svg",
  "metadata": {
    "og:image": "/images/og.png",
    "og:site_name": "gx",
    "og:title": "gx: Git Productivity Toolkit",
    "og:description": "25 commands for everyday git, stacked PRs, and code insight."
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "installation", "quickstart"]
          },
          {
            "group": "Everyday",
            "pages": [
              "commands/undo",
              "commands/oops",
              "commands/switch",
              "commands/context",
              "commands/sweep",
              "commands/shelf"
            ]
          },
          {
            "group": "Insight",
            "pages": [
              "commands/who",
              "commands/recap",
              "commands/drift",
              "commands/conflicts",
              "commands/handoff",
              "commands/view"
            ]
          },
          {
            "group": "Stacking",
            "pages": [
              "stacking/overview",
              "commands/init",
              "commands/stack",
              "commands/sync",
              "commands/retarget",
              "commands/graph",
              "commands/navigate",
              "commands/parent"
            ]
          },
          {
            "group": "Utility",
            "pages": [
              "commands/nuke",
              "commands/update"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/mubbie/gx-cli",
          "icon": "github"
        },
        {
          "anchor": "Releases",
          "href": "https://github.com/mubbie/gx-cli/releases",
          "icon": "tag"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/mubbie/gx-cli"
      },
      {
        "label": "mubbie.dev",
        "href": "https://mubbie.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install",
      "href": "/installation"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/mubbie/gx-cli",
      "website": "https://mubbie.dev"
    }
  }
}
